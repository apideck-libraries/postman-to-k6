{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "includes": [
      "**",
      "!coverage",
      "!**/coverage",
      "!node_modules",
      "!vendor",
      "!.codex",
      "!tmp",
      "!.tmp",
      "!examples/quickpizza/libs",
      "!examples/quickpizza/quickpizza.k6.js",
      "!lib/shim/faker.js"
    ]
  },
  "overrides": [
    {
      "includes": [
        "lib/shim/core.js"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "useGetterReturn": "off"
          },
          "complexity": {
            "useOptionalChain": "off"
          },
          "security": {
            "noGlobalEval": "off"
          }
        }
      }
    }
  ]
}
