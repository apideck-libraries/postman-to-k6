{
  "name": "@apideck/postman-to-k6",
  "version": "1.14.0",
  "description": "Convert a Postman collection to k6 JavaScript",
  "keywords": [
    "k6",
    "postman",
    "loadtest",
    "load-test",
    "load-testing",
    "server-load",
    "performance"
  ],
  "homepage": "https://github.com/apideck-libraries/postman-to-k6#readme",
  "bugs": {
    "url": "https://github.com/apideck-libraries/postman-to-k6/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apideck-libraries/postman-to-k6.git"
  },
  "license": "Apache-2.0",
  "author": "",
  "main": "bin/postman-to-k6.js",
  "bin": {
    "postman-to-k6": "bin/postman-to-k6.js"
  },
  "files": [
    "bin/**/*",
    "lib/**/*",
    "scripts/bundle.js"
  ],
  "directories": {
    "bin": "bin",
    "lib": "lib"
  },
  "scripts": {
    "bundle": "node scripts/bundle.js",
    "lint:fix": "biome lint --write .",
    "lint": "biome lint .",
    "format": "biome format lib test tests scripts bin",
    "format:fix": "biome format --write lib test tests scripts bin",
    "postinstall": "node scripts/bundle.js",
    "test": "npm run test-all",
    "test-ava-suite": "npm --prefix tests/ava-suite run test-all",
    "test-jest:runner": "jest --colors --verbose --reporters=default --collectCoverage --no-cache",
    "test-jest-native-guard": "node scripts/guard-jest-native.js",
    "test-jest": "npm-run-all test-jest-native-guard test-jest:runner",
    "test-all": "npm-run-all test-ava-suite test-jest",
    "coverage-ava": "npm --prefix tests/ava-suite run coverage-ava",
    "coverage-jest": "npm run test-jest",
    "coverage-jest-regression": "node scripts/coverage-regression-check.js",
    "coverage-combine": "node scripts/coverage-combine.js",
    "coverage-all": "npm-run-all coverage-ava coverage-jest coverage-combine",
    "prepare": "husky install",
    "release": "npm run format && npm run lint && npm run bundle && npx np --branch main"
  },
  "dependencies": {
    "ajv": "^6.14.0",
    "aws4": "^1.13.2",
    "browserify": "^17.0.1",
    "chai": "^4.5.0",
    "cheerio": "1.0.0-rc.6",
    "commander": "^2.20.3",
    "crypto-js": "^4.2.0",
    "fs-extra": "^11.3.4",
    "lodash": "^4.17.23",
    "oauth-1.0a": "^2.2.6",
    "papaparse": "^5.5.3",
    "pkginfo": "^0.4.1",
    "postman-collection": "^4.5.0",
    "postman-collection-transformer": "^4.1.13",
    "prettier": "^1.19.1",
    "spo-gpo": "^1.0.0",
    "strip-json-comments": "^3.1.1",
    "urijs": "^1.19.11",
    "uuid": "^3.4.0",
    "verror": "^1.10.1",
    "xml2js": "^0.5.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.28.6",
    "@babel/preset-env": "^7.28.6",
    "@babel/register": "^7.28.6",
    "@babel/runtime": "^7.28.6",
    "@biomejs/biome": "^2.4.7",
    "cross-env": "^7.0.3",
    "husky": "^7.0.4",
    "jest": "^30.3.0",
    "npm-run-all": "^4.1.5",
    "sinon": "^7.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "preferGlobal": true,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
