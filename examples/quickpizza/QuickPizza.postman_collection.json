    {
      "name": "19. Capabilities Variables",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('capFromPre', 'from-pre');",
              "pm.globals.set('capGlobal', 'from-global');",
              "pm.variables.set('capLocal', 'from-local');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('collection/global/local vars are available', function () {",
              "  pm.expect(pm.collectionVariables.get('capFromPre')).to.eql('from-pre');",
              "  pm.expect(pm.globals.get('capGlobal')).to.eql('from-global');",
              "  pm.expect(pm.variables.get('capLocal')).to.eql('from-local');",
              "});",
              "pm.test('pm.info values are exposed', function () {",
              "  pm.expect(pm.info.eventName).to.eql('test');",
              "  pm.expect(pm.info.requestName).to.eql('19. Capabilities Variables');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/get?from={{capFromPre}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "get"],
          "query": [
            { "key": "from", "value": "{{capFromPre}}" }
          ]
        }
