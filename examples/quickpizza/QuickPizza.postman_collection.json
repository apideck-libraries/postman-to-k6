          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "var body = pm.response.json();",
              "pm.test('pm.response.json works', function () {",
              "  pm.expect(body.param1).to.eql('value1');",
              "});",
              "pm.test('jsonBody path/value works', function () {",
              "  pm.response.to.have.jsonBody('param1', 'value1');",
              "});",
              "pm.test('negative status assertion works', function () {",
              "  pm.response.to.not.have.status(500);",
              "});"
            ]
          }
        }
      ]
